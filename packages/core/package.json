{
  "name": "@pulsemcp/air-core",
  "version": "0.0.41",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulsemcp/air.git",
    "directory": "packages/core"
  },
  "description": "AIR core — config resolution, validation, schemas, and extension interfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "schemas/"
  ],
  "scripts": {
    "build": "npm run copy-schemas && tsc",
    "copy-schemas": "cp -r ../../schemas ./schemas",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run copy-schemas"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
